# Vertex AI Platform Configuration
# To use Gemini via Vertex AI, set the project and optionally region
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Environment trigger for Vertex AI mode in google-adk
GOOGLE_GENAI_USE_VERTEXAI=1

# Remote GitHub MCP Server Configuration
# Provide your GitHub Personal Access Token (PAT) with repo/read/write scopes
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# The URL of the remote GitHub MCP Server (defaults to GitHub Copilot's hosted endpoint)
GITHUB_MCP_SSE_URL=https://api.githubcopilot.com/mcp/sse

# Webhook Security & Filtering Configuration
GITHUB_WEBHOOK_SECRET=your_webhook_secret_passphrase
ALLOWED_CODE_REPOS=owner/repo-name

# Automated Documentation Refresher Target Repository
DOCS_TARGET_REPO=owner/repo-docs

